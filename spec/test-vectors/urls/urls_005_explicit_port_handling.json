{
  "id": "urls_005_explicit_port_handling",
  "title": "Explicit non-default ports are preserved across all derived endpoints",
  "initial_state": {
    "base_url": "https://supabase.example.internal:8443"
  },
  "events": [
    { "type": "derive_all_endpoints" }
  ],
  "expected": {
    "normalized_base_url": "https://supabase.example.internal:8443",
    "auth_url": "https://supabase.example.internal:8443/auth/v1",
    "rest_url": "https://supabase.example.internal:8443/rest/v1",
    "realtime_url": "wss://supabase.example.internal:8443/realtime/v1",
    "storage_url": "https://supabase.example.internal:8443/storage/v1",
    "functions_url": "https://supabase.example.internal:8443/functions/v1"
  },
  "invariants": [
    "INV-URL-001",
    "INV-URL-002"
  ],
  "notes": "Port handling must stay structured rather than regex-driven."
}
