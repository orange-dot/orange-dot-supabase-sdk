{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [{ "$ref": "common.schema.json" }],
  "properties": {
    "id": { "pattern": "^urls_\\d{3}_" },
    "initial_state": {
      "type": "object",
      "required": ["base_url"],
      "properties": {
        "base_url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "expected": {
      "type": "object",
      "required": ["normalized_base_url", "auth_url", "rest_url", "realtime_url", "storage_url", "functions_url"],
      "properties": {
        "normalized_base_url": { "type": "string", "format": "uri" },
        "auth_url":            { "type": "string", "format": "uri" },
        "rest_url":            { "type": "string", "format": "uri" },
        "realtime_url":        { "type": "string", "format": "uri" },
        "storage_url":         { "type": "string", "format": "uri" },
        "functions_url":       { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "events": {
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "enum": ["derive_all_endpoints"] }
        },
        "additionalProperties": false
      }
    }
  }
}
